{
  "name": "turf-matrix",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:race-batch": "npm run generate:race-batch && vite --mode batch",
    "build": "vite build",
    "build:race-batch": "npm run generate:race-batch && vite build --mode batch",
    "preview": "vite preview",
    "detect:jvlink": "powershell -ExecutionPolicy Bypass -File tools/jvlink/jvlink-cli.ps1 -Action detect",
    "probe:jvlink": "powershell -ExecutionPolicy Bypass -File tools/jvlink/jvlink-cli.ps1 -Action probe",
    "inspect:jvlink-week": "powershell -ExecutionPolicy Bypass -File tools/jvlink/jvlink-cli.ps1 -Action inspect-week",
    "detect:html": "node tools/target-html/detect-html-inputs.mjs",
    "inspect:rc1b": "node tools/rc1b-inspect-inputs.mjs",
    "inspect:race-batch": "node tools/inspect-race-batch.mjs",
    "scaffold:race-batch": "node tools/scaffold-race-batch-inputs.mjs",
    "normalize:rc1b": "node tools/normalizers/normalized-horse.mjs",
    "normalize:race-batch": "node tools/normalizers/race-batch.mjs",
    "generate:race-batch": "npm run normalize:race-batch && node tools/generate-race-batch-candidate.mjs",
    "thursday:preview": "npm run build:race-batch",
    "prepare:race-release": "node tools/prepare-race-batch-release.mjs",
    "saturday:publish": "powershell -ExecutionPolicy Bypass -File tools/publish-race-batch.ps1",
    "generate:candidate": "npm run generate:race-batch",
    "test:intelligence": "node --test tools/intelligence/tests/*.test.mjs",
    "verify:intelligence": "npm run generate:race-batch && npm run test:intelligence",
    "generate:preodds": "node tools/generate-preodds.mjs",
    "validate:csv": "node tools/validate-csv-inputs.mjs",
    "generate-week": "node tools/generate-week-safe.mjs",
    "weekly:update": "powershell -ExecutionPolicy Bypass -File tools/weekly-update.ps1",
    "update-data": "node tools/update-data.mjs tools/week-data.json src/App.jsx"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11"
  }
}
